{
  "multipart": [
    { "apply": { "model": "createpropulsion:block/cable_inner" } },
    { "when": { "north": "true" }, "apply": { "model": "createpropulsion:block/cable_outer" } },
    { "when": { "east": "true" }, "apply": { "model": "createpropulsion:block/cable_outer", "y": 90 } },
    { "when": { "south": "true" }, "apply": { "model": "createpropulsion:block/cable_outer", "y": 180 } },
    { "when": { "west": "true" }, "apply": { "model": "createpropulsion:block/cable_outer", "y": 270 } },
    { "when": { "up": "true" }, "apply": { "model": "createpropulsion:block/cable_outer", "x": 270 } },
    { "when": { "down": "true" }, "apply": { "model": "createpropulsion:block/cable_outer", "x": 90 } }
  ]
}